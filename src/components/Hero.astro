<section class="relative h-screen flex items-center overflow-hidden bg-farm-deep">
  <div class="absolute inset-0 bg-gradient-to-br from-farm-deep/90 via-farm-forest/80 to-farm-deep"></div>
  <div class="absolute inset-0 bg-[url('/img/breeding.png')] bg-cover bg-center opacity-[0.07]"></div>
  <div class="absolute inset-0 bg-[url('/pattern.png')] bg-repeat bg-[length:250px] opacity-[0.06]"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-farm-deep via-farm-deep/50 to-transparent"></div>

  <div class="absolute top-1/3 -left-24 w-80 h-80 bg-farm-green/15 rounded-full blur-[120px] float"></div>
  <div class="absolute bottom-1/3 -right-24 w-96 h-96 bg-farm-gold/10 rounded-full blur-[140px] float-slow"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-farm-greenLight/5 rounded-full blur-[160px]"></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-4 sm:px-6 pt-20 sm:pt-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-10 lg:gap-14 items-center">
      <div class="order-last lg:order-none glass rounded-2xl sm:rounded-3xl p-5 sm:p-9 lg:p-11 shadow-2xl shadow-black/20">
        <span class="inline-block text-farm-greenLight/80 text-[10px] sm:text-sm tracking-[0.25em] uppercase mb-2 sm:mb-4 font-medium">
          Agriculture Platform
        </span>
        <h1 class="text-3xl sm:text-5xl lg:text-6xl xl:text-7xl font-black text-white leading-[1.1] mb-3 sm:mb-7 tracking-tight">
          Nusantara<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-farm-greenLight to-farm-green">Farmer Group</span>
        </h1>
        <p class="text-white/40 text-xs sm:text-sm lg:text-lg leading-relaxed mb-5 sm:mb-9 max-w-lg">
          Hello True Farmers. Thank You. you have come to the right place. a gathering place for all farmers to share knowledge and experience.
        </p>
        <div class="flex flex-wrap gap-2 sm:gap-4">
          <button class="px-5 sm:px-9 py-2.5 sm:py-3.5 bg-farm-green text-white font-semibold rounded-xl transition-all duration-300 shadow-lg shadow-farm-green/25 text-xs sm:text-base btn-primary">
            Join Discussion
          </button>
          <button class="px-5 sm:px-9 py-2.5 sm:py-3.5 glass text-white/60 rounded-xl transition-all duration-300 text-xs sm:text-base btn-glass">
            Explore More
          </button>
        </div>
      </div>
      <img src="/img/breeding.png" alt="Agriculture Platform" class="order-first lg:order-none w-full h-auto rounded-3xl" />
    </div>
  </div>
