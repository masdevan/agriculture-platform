---
const products = [
  {
    title: 'Fertilizer',
    description: 'Cheap Quality Fertilizer. get it now and breed your plants thoroughly and keep your plants healthy regularly. Original organic fertilizer from the best selected high quality ingredients!',
  },
  {
    title: 'Seeds',
    description: 'Get the best planting seeds now and the quality is maintained. get an abundant and guaranteed harvest. only here. feel the difference and enjoy the advantages right now!',
  },
  {
    title: 'Tools',
    description: 'High quality agricultural tools are sturdy and strong for farming. try it now and enjoy the quality. using selected high quality iron. Rustproof and sturdy. Try this tool now.',
  },
];
---

<section class="relative py-16 sm:py-28 lg:py-36 overflow-hidden bg-white">
  <div class="absolute inset-0 bg-[url('/pattern.png')] bg-repeat bg-[length:250px] opacity-[0.05]"></div>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-farm-green/5 rounded-full blur-[150px]"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-farm-gold/6 rounded-full blur-[120px]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8 sm:mb-16">
      <span class="inline-block text-farm-green text-[10px] sm:text-sm tracking-[0.25em] uppercase mb-2 sm:mb-3 font-semibold">Our Products</span>
      <h2 class="text-2xl sm:text-4xl lg:text-5xl font-black text-farm-deep tracking-tight">Shop Menu</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
      {products.map((product, i) => (
        <div class="bg-white/90 backdrop-blur-md rounded-2xl p-5 sm:p-8 transition-all duration-500 hover:-translate-y-2 shadow-lg shadow-black/5 hover:shadow-xl text-center sm:text-left flex flex-col">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-farm-green/10 rounded-xl sm:rounded-2xl flex items-center justify-center mb-3 sm:mb-5 mx-auto sm:mx-0">
            <span class="text-farm-green text-base sm:text-xl font-bold">{String.fromCharCode(65 + i)}</span>
          </div>
          <h3 class="text-base sm:text-xl font-bold text-farm-deep mb-2 sm:mb-3 leading-tight">{product.title}</h3>
          <p class="text-gray-400 text-xs sm:text-sm leading-relaxed mb-5 sm:mb-8 flex-1">{product.description}</p>
          <button class="w-full sm:w-auto px-5 sm:px-6 py-2.5 sm:py-3 bg-farm-green text-white font-medium rounded-xl hover:bg-farm-leaf transition-all duration-300 text-xs sm:text-sm btn-primary self-start">
            Buy Now
          </button>
        </div>
      ))}
    </div>
  </div>
</section>
