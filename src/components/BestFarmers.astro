  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-farm-gold/6 rounded-full blur-[160px]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
