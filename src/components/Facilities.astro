---
const facilities = [
  {
    title: 'Promotion Media',
    description: 'On this website you are free to carry out any promotions related to agriculture. However, please note that you also include information. what do you share or promote!',
  },
  {
    title: 'Question and Answer',
    description: "Don't ever be embarrassed to ask everyone. and it is hoped that experienced farmers will also share information about what is being asked so that it will be useful now and in the future!",
  },
  {
    title: 'Sharing Experiences',
    description: 'Never be embarrassed to share your experiences. because your experience is the best correction for us farmers who are struggling to fertilize crops to become food!',
  },
];
---

<section class="relative py-16 sm:py-28 lg:py-36 overflow-hidden bg-farm-deep">
  <div class="absolute inset-0 bg-gradient-to-b from-farm-deep via-farm-forest/60 to-farm-deep"></div>
  <div class="absolute inset-0 bg-[url('/pattern.png')] bg-repeat bg-[length:250px] opacity-[0.05]"></div>
  <div class="absolute top-1/3 right-0 w-96 h-96 bg-farm-greenLight/8 rounded-full blur-[130px] float-slow"></div>
  <div class="absolute bottom-1/4 left-0 w-72 h-72 bg-farm-green/10 rounded-full blur-[110px] float" style="animation-delay: 2s"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8 sm:mb-16">
      <span class="inline-block text-farm-greenLight/70 text-[10px] sm:text-sm tracking-[0.25em] uppercase mb-2 sm:mb-3 font-medium">Facilities</span>
      <h2 class="text-2xl sm:text-4xl lg:text-5xl font-black text-white tracking-tight">What We Offer</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-10 lg:gap-14 items-center">
      <div class="order-last lg:order-none space-y-4 sm:space-y-6">
        {facilities.map((item, i) => (
          <div class="flex gap-3 sm:gap-5 glass rounded-xl sm:rounded-2xl p-4 sm:p-6 hover:bg-white/[0.10] transition-all duration-500">
            <div class="w-9 h-9 sm:w-12 sm:h-12 glass rounded-lg sm:rounded-xl flex items-center justify-center shrink-0 mt-0.5 shadow-lg shadow-black/10">
              <span class="text-farm-greenLight text-sm sm:text-xl font-bold">{i + 1}</span>
            </div>
            <div>
              <h3 class="text-sm sm:text-lg font-bold text-white mb-1 sm:mb-1.5">{item.title}</h3>
              <p class="text-white/35 text-xs sm:text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
      <img src="/img/statisticaly.png" alt="Statistics" class="order-first lg:order-none w-full h-auto rounded-2xl" />
    </div>
  </div>
</section>
