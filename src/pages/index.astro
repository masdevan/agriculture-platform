---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Farmer Group - By Devan Yudistira Sugiharta">
  <!-- Header -->
  <header class="shadow-md bg-farm-tan">
    <div class="max-w-[1150px] mx-auto">
      <div class="mx-4 lg:mx-6">
        <ul class="flex flex-nowrap justify-center overflow-auto">
          <li><a href="#" class="inline-block text-sm px-3 lg:px-4 py-5 text-white hover:text-black transition-colors duration-300">Contoh</a></li>
          <li><a href="#" class="inline-block text-sm px-3 lg:px-4 py-5 text-white hover:text-black transition-colors duration-300">Contoh</a></li>
          <li><a href="#" class="inline-block text-sm px-3 lg:px-4 py-5 text-white hover:text-black transition-colors duration-300">Contoh</a></li>
          <li><a href="#" class="inline-block text-sm px-3 lg:px-4 py-5 text-white hover:text-black transition-colors duration-300">Contoh</a></li>
          <li><a href="#" class="inline-block text-sm px-3 lg:px-4 py-5 text-white hover:text-black transition-colors duration-300">Contoh</a></li>
        </ul>
      </div>
    </div>
  </header>

  <!-- Welcome Point -->
  <div class="relative w-full py-12 lg:py-16 overflow-hidden">
    <div class="max-w-[1150px] mx-auto">
      <div class="mx-4 lg:mx-6 flex flex-wrap items-center">
        <div class="w-full lg:w-1/2">
          <img src="/img/breeding.png" alt="Nusantara Farmer Group" class="w-full h-auto" />
        </div>
        <div class="w-full lg:w-1/2 lg:pl-8 mt-8 lg:mt-0">
          <h1 class="font-heading font-bold text-3xl lg:text-4xl mb-5">Nusantara Farmer Group</h1>
          <h4 class="font-body font-normal text-base lg:text-lg leading-relaxed mb-5">
            Hello True Farmers. Thank You. you have come to the right place. a gathering place for all farmers to share knowledge and experience. wave of promotions and purchases of seeds or other technical matters. Don't be embarrassed to ask questions or express opinions here. This is the place for you to express and explore!
          </h4>
          <button class="appearance-none border-none outline-none px-4 py-2.5 rounded text-white bg-farm-green hover:bg-farm-green-dark transition-colors duration-300 cursor-pointer font-body text-sm my-2.5">
            Join Discussion
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Shop Menu -->
  <div class="relative w-full py-12 lg:py-16 overflow-hidden bg-farm-section">
    <div class="max-w-[1150px] mx-auto">
      <div class="mx-4 lg:mx-6 text-center">
        <h1 class="font-heading font-bold text-3xl lg:text-4xl mb-5">Shop Menu</h1>
      </div>
      <div class="mx-4 lg:mx-6 flex flex-col lg:flex-row">
        <div class="flex-1 p-8 lg:p-10 mx-0 lg:mx-4 my-2 lg:my-0 rounded shadow-md bg-farm-tan hover:bg-farm-tan-hover transition-colors duration-300 text-center">
          <h3 class="font-heading font-bold text-xl lg:text-2xl text-white">Fertilizer</h3>
          <strong class="block my-5 lg:my-6 text-gray-100 font-body font-normal">
            Cheap Quality Fertilizer. get it now and breed your plants thoroughly and keep your plants healthy regularly. Original organic fertilizer from the best selected high quality ingredients!
          </strong>
          <button class="appearance-none border-none outline-none px-6 py-1.5 rounded text-[#232323] bg-farm-bg hover:bg-white transition-colors duration-300 cursor-pointer font-body text-sm">
            Buy Now
          </button>
        </div>

        <div class="flex-1 p-8 lg:p-10 mx-0 lg:mx-4 my-2 lg:my-0 rounded shadow-md bg-farm-tan hover:bg-farm-tan-hover transition-colors duration-300 text-center">
          <h3 class="font-heading font-bold text-xl lg:text-2xl text-white">Seeds</h3>
          <strong class="block my-5 lg:my-6 text-gray-100 font-body font-normal">
            Get the best planting seeds now and the quality is maintained. get an abundant and guaranteed harvest. only here. feel the difference and enjoy the advantages right now!
          </strong>
          <button class="appearance-none border-none outline-none px-6 py-1.5 rounded text-[#232323] bg-farm-bg hover:bg-white transition-colors duration-300 cursor-pointer font-body text-sm">
            Buy Now
          </button>
        </div>

        <div class="flex-1 p-8 lg:p-10 mx-0 lg:mx-4 my-2 lg:my-0 rounded shadow-md bg-farm-tan hover:bg-farm-tan-hover transition-colors duration-300 text-center">
          <h3 class="font-heading font-bold text-xl lg:text-2xl text-white">Tools</h3>
          <strong class="block my-5 lg:my-6 text-gray-100 font-body font-normal">
            High quality agricultural tools are sturdy and strong for farming. try it now and enjoy the quality. using selected high quality iron. Rustproof and sturdy. Try this tool now. Don't Miss It!
          </strong>
          <button class="appearance-none border-none outline-none px-6 py-1.5 rounded text-[#232323] bg-farm-bg hover:bg-white transition-colors duration-300 cursor-pointer font-body text-sm">
            Buy Now
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Site Facilities -->
  <div class="relative w-full py-12 lg:py-16 overflow-hidden">
    <div class="max-w-[1150px] mx-auto">
      <div class="mx-4 lg:mx-6 flex flex-wrap items-center">
        <div class="w-full lg:w-1/2 order-2 lg:order-1">
          <div class="flex flex-col p-5 rounded shadow-md bg-farm-card hover:bg-farm-card-hover mb-5 lg:mr-[70px] transition-colors duration-300">
            <h2 class="font-heading font-bold text-xl lg:text-2xl text-white mb-1">Promotion Media</h2>
            <strong class="text-[#B6EDAA] font-body font-normal">
              On this website you are free to carry out any promotions related to agriculture. However, please note that you also include information. what do you share or promote!
            </strong>
          </div>
          <div class="flex flex-col p-5 rounded shadow-md bg-farm-card hover:bg-farm-card-hover mb-5 lg:mr-[70px] transition-colors duration-300">
            <h2 class="font-heading font-bold text-xl lg:text-2xl text-white mb-1">Question and Answer</h2>
            <strong class="text-[#B6EDAA] font-body font-normal">
              Don't ever be embarrassed to ask everyone. and it is hoped that experienced farmers will also share information about what is being asked so that it will be useful now and in the future!
            </strong>
          </div>
          <div class="flex flex-col p-5 rounded shadow-md bg-farm-card hover:bg-farm-card-hover mb-5 lg:mr-[70px] transition-colors duration-300">
            <h2 class="font-heading font-bold text-xl lg:text-2xl text-white mb-1">Sharing Experiences</h2>
            <strong class="text-[#B6EDAA] font-body font-normal">
              Never be embarrassed to share your experiences. because your experience is the best correction for us farmers who are struggling to fertilize crops to become food!
            </strong>
          </div>
        </div>
        <div class="w-full lg:w-1/2 order-1 lg:order-2 mb-8 lg:mb-0">
          <img src="/img/statisticaly.png" alt="Statistics" class="w-full h-auto" />
        </div>
      </div>
    </div>
  </div>

  <!-- Best Farmers -->
  <div class="relative w-full py-12 lg:py-16 overflow-hidden bg-farm-section">
    <div class="max-w-[1150px] mx-auto">
      <div class="mx-4 lg:mx-6 flex flex-wrap items-center">
        <div class="w-full lg:w-1/2 mb-8 lg:mb-0">
          <img src="/img/glasshome.png" alt="Organic Farming" class="w-full h-auto" />
        </div>
        <div class="w-full lg:w-1/2 lg:pl-8">
          <h1 class="font-heading font-bold text-3xl lg:text-4xl mb-4">the best farmers are organic farmers</h1>
          <p class="font-body font-normal text-base leading-relaxed">
            Be a pure farmer who uses organic-based ingredients and not chemicals. keep the community and people around you healthy. then your finances will be completely healthy. Don't harm others for personal gain. Greetings farmers!
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Wise Message -->
  <div class="relative w-full py-12 lg:py-16 overflow-hidden">
    <div class="max-w-[1150px] mx-auto">
      <div class="mx-4 lg:mx-6 text-center">
        <h1 class="font-heading font-bold text-3xl lg:text-4xl">Wise Message for Farmers</h1>
        <div class="p-8 lg:p-12 rounded my-8 shadow-md bg-farm-plank font-body font-normal text-base leading-relaxed">
          be a wise farmer. Farmers are the core of the world's food sector. use your skills perfectly so as to produce maximum results for the food sector. revive the world economy. stabilize the world food problem. utilize the country's potential wisely. Greetings farmer!
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="relative w-full py-12 lg:py-16 overflow-hidden z-[1]">
    <div class="absolute inset-0 bg-[url('/img/foot.jpg')] bg-cover bg-center z-[2]"></div>
    <div class="absolute inset-0 bg-black/60 z-[3]"></div>
    <div class="max-w-[1150px] mx-auto relative z-10">
      <div class="mx-4 lg:mx-6 flex flex-wrap">
        <div class="w-full lg:w-1/2 mb-8 lg:mb-0">
          <h1 class="font-heading font-bold text-3xl lg:text-4xl text-white mb-4">About This Farmer Group Indonesia</h1>
          <p class="font-body font-normal text-base leading-relaxed text-gray-300">
            This is a community for buying and selling agricultural materials. and discussion forums regarding agriculture. And to share experiences
          </p>
          <button class="appearance-none border-none outline-none px-4 py-2.5 rounded text-white bg-farm-green hover:bg-farm-green-dark transition-colors duration-300 cursor-pointer font-body text-sm my-2.5 mt-4">
            Collaborate
          </button>
        </div>
        <div class="w-full lg:w-1/2">
          <div class="block w-full lg:w-[70%] ml-auto bg-white rounded shadow-md">
            <div class="p-6 lg:p-8">
              <h3 class="font-heading font-bold text-lg lg:text-xl mb-4">Hello Farmer Team. Join Here!</h3>
              <input type="text" placeholder="Email..." class="appearance-none border-none outline-none border-b border-gray-300 w-full my-2.5 py-2.5 font-body text-sm" />
              <input type="password" placeholder="Password..." class="appearance-none border-none outline-none border-b border-gray-300 w-full my-2.5 py-2.5 font-body text-sm" />
              <input type="text" placeholder="Farm Area..." class="appearance-none border-none outline-none border-b border-gray-300 w-full my-2.5 py-2.5 font-body text-sm" />
              <button class="appearance-none border-none outline-none px-4 py-2.5 rounded text-white bg-farm-green hover:bg-farm-green-dark transition-colors duration-300 cursor-pointer font-body text-sm my-2.5">
                Bergabung
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <!-- Credits -->
  <div class="text-center bg-farm-green-dark py-6">
    <div class="max-w-[1150px] mx-auto">
      <strong class="text-white text-sm font-body font-normal">
        Copyright &copy; 2023. Devan Yudistira Sugiharta. All Rights Reserved.
      </strong>
    </div>
  </div>
</Layout>
